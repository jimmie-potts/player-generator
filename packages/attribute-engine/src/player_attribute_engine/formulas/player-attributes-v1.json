{
  "schemaVersion": 1,
  "formulaVersion": "1.0.0",
  "referenceContractVersion": 1,
  "outputFields": [
    "playerId",
    "insideScoring",
    "threePointShooting",
    "freeThrowShooting",
    "scoringVolume",
