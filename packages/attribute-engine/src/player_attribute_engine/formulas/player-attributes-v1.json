    "adjustedThreePointPercentage": {
      "kind": "stabilizedPercentage",
      "inputs": ["threePointersMade", "threePointersAttempted"],
      "priorAttempts": 100
    },
    "adjustedFreeThrowPercentage": {
      "kind": "stabilizedPercentage",
      "inputs": ["freeThrowsMade", "freeThrowsAttempted"],
      "priorAttempts": 75
    },
    "freeThrowRate": {
      "kind": "ratio",
      "inputs": ["freeThrowsAttempted", "fieldGoalsAttempted"]
    },
    "availability": {
      "kind": "scheduledRatio",
      "inputs": ["games", "season"],
      "schedule": {
        "2021": 72,
        "2022": 82,
        "2023": 82,
        "2024": 82,
        "2025": 82,
        "2026": 82
      }
    }
  },
  "cohorts": {
    "season": {"groupBy": ["season"]}
