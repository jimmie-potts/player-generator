  "relationships": [
    {
      "name": "playerStatsReferencePlayers",
      "kind": "foreignKey",
      "from": {"file": "player_stats.csv", "columns": ["playerId"]},
      "to": {"file": "players.csv", "columns": ["playerId"]}
    },
    {
      "name": "playerAdvancedStatsReferencePlayers",
      "kind": "foreignKey",
      "from": {"file": "player_advanced_stats.csv", "columns": ["playerId"]},
      "to": {"file": "players.csv", "columns": ["playerId"]}
    },
    {
      "name": "playerAttributesReferencePlayers",
      "kind": "foreignKey",
      "from": {"file": "player_attributes.csv", "columns": ["playerId"]},
      "to": {"file": "players.csv", "columns": ["playerId"]}
    },
    {
      "name": "rosterPlayerSet",
      "kind": "exactKeySet",
      "files": ["players.csv", "player_stats.csv", "player_advanced_stats.csv", "player_attributes.csv"],
      "columns": ["playerId"]
    },
    {
      "name": "rosterPlayerSeasonGrain",
      "kind": "exactKeySet",
      "files": ["player_stats.csv", "player_advanced_stats.csv"],
      "columns": ["playerId", "season"]
    }
  ]
