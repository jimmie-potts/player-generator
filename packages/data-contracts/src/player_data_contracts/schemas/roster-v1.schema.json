{
  "title": "Roster CSV package contract",
  "description": "Version 1 ordered CSV columns, scalar types, keys, and relationships for generated player-only roster data.",
  "contractVersion": 1,
  "encoding": "UTF-8",
  "lineEnding": "LF",
  "files": {
    "players.csv": {
      "columns": [
        {"name": "playerId", "type": "string", "required": true, "nullable": false, "pattern": "^player_[0-9a-f]{16}$"},
        {"name": "displayName", "type": "string", "required": true, "nullable": false},
        {"name": "firstName", "type": "string", "required": true, "nullable": false},
        {"name": "lastName", "type": "string", "required": true, "nullable": false},
        {"name": "age", "type": "integer", "required": false, "nullable": true, "minimum": 18, "maximum": 45},
        {"name": "heightInches", "type": "integer", "required": false, "nullable": true, "minimum": 60, "maximum": 96},
        {"name": "weightPounds", "type": "integer", "required": false, "nullable": true, "minimum": 140, "maximum": 350}
      ],
      "uniqueKeys": [["playerId"]]
    },
