        {"name": "freeThrowShooting", "type": "integer", "required": true, "nullable": false, "minimum": 25, "maximum": 99},
        {"name": "scoringVolume", "type": "integer", "required": true, "nullable": false, "minimum": 25, "maximum": 99},
        {"name": "playmaking", "type": "integer", "required": true, "nullable": false, "minimum": 25, "maximum": 99},
        {"name": "ballSecurity", "type": "integer", "required": true, "nullable": false, "minimum": 25, "maximum": 99},
